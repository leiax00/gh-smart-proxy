# 本地开发用 .env（docker compose 自动加载同目录 .env）。
# 服务器部署时不需要这个文件：CI 会注入 IMAGE（自动计算）和 PROXY_SECRET（来自 Gitea secret）。
# 只在本地跑 docker、或想在服务器覆盖 ADDR/RATE 等时才用。

# 本地构建的镜像 tag（配合 compose 里的 build:）
IMAGE=gh-smart-proxy:local

# URL 鉴权 secret；留空 = 开放代理模式（见 README）
PROXY_SECRET=改成你的长随机secret

# 可选覆盖：
# ADDR=:8080
# RATE_LIMIT=120
# RATE_WINDOW_SECONDS=60
# TZ=Asia/Shanghai
